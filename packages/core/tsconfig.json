{
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "build",
    "incremental": true,
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "declaration": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true,
    "alwaysStrict": true,
    "target": "es2017",
    "lib": [
      "ES2019"
    ],
    "types": ["node", "mocha"],
    "sourceMap": true
  },
  "filesGlob": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
