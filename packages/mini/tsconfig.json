{
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "build",
    "incremental": true,
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "declaration": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "forceConsistentCasingInFileNames": true,
    "alwaysStrict": true,
    "target": "es2019",
    "lib": [
      "ES2019",
      "DOM"
    ],
    "sourceMap": true
  },
  "filesGlob": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}